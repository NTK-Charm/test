# Example environment file for local development and CI.
# Copy this to .env and replace placeholder values with your own secrets.

# Database Configuration
MARIADB_ROOT_PASSWORD=change_me_root_password
MARIADB_DATABASE=wordpress_db
MARIADB_USER=wordpress_user
MARIADB_PASSWORD=change_me_user_password

# WordPress Configuration
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_USER=wordpress_user
WORDPRESS_DB_PASSWORD=change_me_user_password
WORDPRESS_DB_NAME=wordpress_db

# Additional Security Settings
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=false
WORDPRESS_CONFIG_EXTRA=define('WP_DEBUG_LOG', false);

# Environment indicator
ENVIRONMENT=development
DOMAIN=localhost
